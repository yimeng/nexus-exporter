{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Nexus Repository Manager - SRE Dashboard",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "datasource": null,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "🎯 Service Availability",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Nexus service availability - 1 means UP, 0 means DOWN",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]},
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "expr": "nexus_up",
          "refId": "A",
          "legendFormat": "Nexus Status"
        }
      ],
      "title": "Nexus Availability",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Current Nexus version",
      "fieldConfig": {
        "defaults": {"custom": {"displayMode": "json-view"}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "targets": [
        {
          "expr": "nexus_version_info",
          "refId": "A",
          "legendFormat": "Version: {{version}} ({{edition}})"
        }
      ],
      "title": "Nexus Version",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Uptime percentage over last 24h",
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.99}, {"color": "green", "value": 0.999}]},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "targets": [
        {
          "expr": "avg_over_time(nexus_up[24h])",
          "refId": "A",
          "legendFormat": "24h Uptime"
        }
      ],
      "title": "Uptime (24h)",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Number of repositories",
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "targets": [
        {
          "expr": "count(nexus_repository_info)",
          "refId": "A",
          "legendFormat": "Repositories"
        }
      ],
      "title": "Total Repositories",
      "type": "stat"
    },
    {
      "collapsed": false,
      "datasource": null,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 6,
      "panels": [],
      "title": "💾 Storage Capacity",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Blob store usage over time",
      "fieldConfig": {
        "defaults": {"custom": {"drawStyle": "line", "lineWidth": 2}, "unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"]}},
      "targets": [
        {
          "expr": "nexus_blobstore_bytes_total",
          "refId": "A",
          "legendFormat": "{{name}} - Used"
        },
        {
          "expr": "nexus_blobstore_bytes_free",
          "refId": "B",
          "legendFormat": "{{name}} - Free"
        }
      ],
      "title": "Blob Store Usage",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "description": "Blob store disk usage percentage",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]},
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 8,
      "options": {"displayMode": "lcd", "orientation": "horizontal", "showUnfilled": true},
      "targets": [
        {
          "expr": "(nexus_blobstore_bytes_total / (nexus_blobstore_bytes_total + nexus_blobstore_bytes_free)) * 100",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Disk Usage % (Blob Store)",
      "type": "gauge"
    },
    {
      "datasource": "${datasource}",
      "description": "Number of blobs per blob store",
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 14},
      "id": 9,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "expr": "nexus_blobstore_blobs_count",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Blob Count",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Components count by repository",
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 14},
      "id": 10,
      "options": {"displayMode": "value", "graphMode": "area"},
      "targets": [
        {
          "expr": "nexus_repository_components_count",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Components by Repository",
      "type": "stat"
    },
    {
      "collapsed": false,
      "datasource": null,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 11,
      "panels": [],
      "title": "☕ JVM Performance",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "JVM memory usage",
      "fieldConfig": {
        "defaults": {"custom": {"drawStyle": "line", "lineWidth": 2}, "unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 19},
      "id": 12,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "expr": "nexus_jvm_memory_used_bytes",
          "refId": "A",
          "legendFormat": "Used - {{area}}"
        },
        {
          "expr": "nexus_jvm_memory_max_bytes",
          "refId": "B",
          "legendFormat": "Max - {{area}}"
        }
      ],
      "title": "JVM Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "description": "JVM thread count",
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19},
      "id": 13,
      "options": {"legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "nexus_jvm_threads_count",
          "refId": "A",
          "legendFormat": "Threads"
        }
      ],
      "title": "JVM Thread Count",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "datasource": null,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 14,
      "panels": [],
      "title": "⚙️ Task Health",
      "type": "row"
    },
    {
      "datasource": "${datasource}",
      "description": "Total number of scheduled tasks",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": 0}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 0, "y": 28},
      "id": 50,
      "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "targets": [
        {
          "expr": "count(nexus_task_status)",
          "refId": "A"
        }
      ],
      "title": "📊 Total Tasks",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Number of healthy tasks",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 6, "y": 28},
      "id": 51,
      "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "targets": [
        {
          "expr": "count(nexus_task_status == 1)",
          "refId": "A"
        }
      ],
      "title": "✅ Healthy Tasks",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Number of failed tasks",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "mappings": [
            {"options": {"0": {"color": "green", "text": "OK"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 12, "y": 28},
      "id": 52,
      "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "targets": [
        {
          "expr": "count(nexus_task_status == 0)",
          "refId": "A"
        }
      ],
      "title": "❌ Failed Tasks",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Task health percentage",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 80},
              {"color": "green", "value": 95}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 3, "w": 6, "x": 18, "y": 28},
      "id": 53,
      "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "targets": [
        {
          "expr": "(count(nexus_task_status == 1) / count(nexus_task_status)) * 100",
          "refId": "A"
        }
      ],
      "title": "🎯 Health Rate",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "description": "Task health status overview",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "text": "❌ FAILED"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "✅ OK"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          },
          "custom": {
            "displayMode": "color-background",
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"options": {"0": {"color": "red", "text": "❌ FAILED"}}, "type": "value"},
                  {"options": {"1": {"color": "green", "text": "✅ OK"}}, "type": "value"}
                ]
              },
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "width", "value": 100}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Task Name"},
            "properties": [
              {"id": "width", "value": 300}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Task Type"},
            "properties": [
              {"id": "width", "value": 250}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Last Run"},
            "properties": [
              {"id": "unit", "value": "dateTimeAsLocal"},
              {"id": "width", "value": 180}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 31},
      "id": 15,
      "targets": [
        {
          "expr": "nexus_task_status",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "nexus_task_last_run_timestamp * 1000",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "📋 Task Health Status",
      "type": "table",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Task Name",
              "type": "Task Type",
              "Value #A": "Status",
              "Value #B": "Last Run"
            },
            "excludeByName": {
              "Time": true,
              "id": true
            },
            "indexByName": {
              "Task Name": 0,
              "Task Type": 1,
              "Status": 2,
              "Last Run": 3
            }
          }
        }
      ]
    },
    {
      "datasource": "${datasource}",
      "description": "Repository capacity, status and metrics",
      "fieldConfig": {
        "defaults": {
          "custom": {"displayMode": "auto", "inspect": false},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"options": {"0": {"color": "red", "text": "Offline"}}, "type": "value"},
                  {"options": {"1": {"color": "green", "text": "Online"}}, "type": "value"}
                ]
              },
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Size"},
            "properties": [
              {"id": "unit", "value": "bytes"},
              {"id": "custom.displayMode", "value": "gradient-gauge"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Assets"},
            "properties": [{"id": "unit", "value": "short"}]
          },
          {
            "matcher": {"id": "byName", "options": "Components"},
            "properties": [{"id": "unit", "value": "short"}]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 39},
      "id": 16,
      "targets": [
        {
          "expr": "nexus_repository_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "nexus_repository_online",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "nexus_repository_components_count",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "nexus_repository_assets_count",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "nexus_repository_size_bytes",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "title": "Repository Capacity & Status",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "name"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Name",
              "format": "Format",
              "type": "Type",
              "blob_store": "Blob Store",
              "Value #A": "_",
              "Value #B": "Status",
              "Value #C": "Components",
              "Value #D": "Assets",
              "Value #E": "Size"
            },
            "excludeByName": {
              "_": true,
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "Name": 0,
              "Format": 1,
              "Type": 2,
              "Status": 3,
              "Components": 4,
              "Assets": 5,
              "Size": 6,
              "Blob Store": 7
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "style": "dark",
  "tags": ["nexus", "sre", "monitoring"],
  "templating": {"list": [{"name": "datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0, "includeAll": false, "multi": false, "options": [], "refresh": 1, "regex": "", "skipUrlSync": false, "title": "Data Source", "description": "Select Prometheus or VictoriaMetrics data source"}]},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {"refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]},
  "timezone": "browser",
  "title": "Nexus SRE Dashboard",
  "uid": "nexus-sre",
  "version": 1
}
